# Legacy: env vars are used as fallback if tls.key_path is not configured.
# When tls.key_path is set, secrets are encrypted at rest in SQLite.
# On first run with tls.key_path, visit /setup to configure secrets,
# or set these env vars to auto-migrate them into encrypted storage.
# DRIFT_ROUTER_PASSWORD=<router ion-drift user password>
# DRIFT_OIDC_SECRET=<keycloak ion-drift client secret>
# DRIFT_SESSION_SECRET=<random string for session signing>
